{
  "name": "openid-guard-backend",
  "version": "1.0.0",
  "description": "Privacy-respecting identity verification API for the web",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openid",
    "authentication",
    "security",
    "identity",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.3.0",
    "@fastify/helmet": "^10.1.1",
    "@fastify/rate-limit": "^8.0.3",
    "@supabase/supabase-js": "^2.105.0",
    "axios": "^1.15.2",
    "did-jwt": "^8.0.9",
    "did-resolver": "^4.1.0",
    "dotenv": "^16.0.3",
    "fastify": "^5.8.5",
    "key-did-resolver": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.16.3",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "@typescript-eslint/parser": "^5.59.2",
    "eslint": "^8.39.0",
    "jest": "^29.7.0",
    "pino-pretty": "^10.0.0",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
